{
  "name": "open-workflow-registry-builder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Builds stable local registry data from validated Workflow Packages",
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "tsc -p tsconfig.build.json",
    "build-registry": "node --import tsx src/cli.ts"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
