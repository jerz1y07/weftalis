{
  "name": "open-workflow-registry-validator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local validator for Open Workflow Registry packages",
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0"
  },
  "scripts": {
    "validate": "node --import tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "spdx-expression-parse": "^5.0.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/spdx-expression-parse": "^4.0.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
